{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-2xl mx-auto mt-8 space-y-6">

        {% for post in posts %}
            <div class="bg-yellow-100 rounded-2xl shadow p-6">
                <div class="flex items-center mb-4">
                    {# Ajoutrer la photo de profile #}
                    <div class="w-12 h-12 rounded-full bg-gray-300 mr-4"></div>


                    <div>
                        <p class="font-semibold">{{ post.author.email }}</p>
                        <p class="text-sm text-gray-600">{{ post.createdAt|date('d/m/Y') }}</p>
                    </div>
                </div>


                <p class="text-gray-800 mb-4 whitespace-pre-line">{{ post.content }}</p>



                {% for image in post.images %}
                    <img src="{{ vich_uploader_asset(image, 'imageFile') }}" alt="" class="rounded-xl max-w-xs h-auto mb-5">
                {% endfor %}


                {# {% include 'like/like.html.twig' %}  Ajouter ici les boutons pour les emojis  #}
                <div class="flex mb-5 gap-4 text-2xl mt-2">

                    <button type="button" class="text-blue-700 border border-blue-700 hover:bg-blue-700 hover:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-full text-sm p-2.5 text-center inline-flex items-center dark:border-blue-500 dark:text-blue-500 dark:hover:text-white dark:focus:ring-blue-800 dark:hover:bg-blue-500">
                        <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 18 18">
                            <path d="M3 7H1a1 1 0 0 0-1 1v8a2 2 0 0 0 4 0V8a1 1 0 0 0-1-1Zm12.954 0H12l1.558-4.5a1.778 1.778 0 0 0-3.331-1.06A24.859 24.859 0 0 1 6 6.8v9.586h.114C8.223 16.969 11.015 18 13.6 18c1.4 0 1.592-.526 1.88-1.317l2.354-7A2 2 0 0 0 15.954 7Z"/>
                        </svg>
                        <span class="sr-only">Icon description</span>
                    </button>
                </div>


                {% for comment in post.comments %}
                    <div class="mb-4">
                        <div class="flex items-center mb-2">
                            <div class="w-10 h-10 rounded-full bg-gray-300 mr-3"></div>
                            <div>
                                <p class="font-semibold text-sm">{{ comment.author.email }}</p>
                                <p class="text-xs text-gray-500">{{ comment.createdAt|date('d/m/Y') }}</p>
                            </div>
                        </div>
                        <div class="bg-white p-3 rounded-xl shadow-inner">
                            <p class="text-gray-800">{{ comment.content }}</p>
                        </div>

                        {# {% include 'like/like.html.twig' %}  Ajouter ici les boutons pour les emojis  #}
                        <div class="flex gap-3 text-2xl mt-2">
                            <span>❤️</span><span>😍</span><span>😄</span>
                        </div>
                    </div>
                {% else %}
                    <p class="text-sm text-gray-400 whitespace-pre-line">Aucun commentaire pour l’instant.</p>
                {% endfor %}





                {% if app.user %}
                    {{ form_start(commentForms[post.id], { action: path('app_comment', {id: post.id}) }) }}
                    <div class="flex items-center gap-3 mt-6">
                        <div class="w-10 h-10 rounded-full bg-gray-300"></div>
                        <div class="flex-grow">
                            {{ form_widget(commentForms[post.id].content, {
                                'attr': {
                                    'placeholder': 'Écrire un commentaire...',
                                    'class': 'w-full border rounded-xl px-4 py-2 focus:outline-none'
                                }
                            }) }}
                            <br>
                        </div>
                        <button type="submit" class="text-xl">Envoyer</button>
                    </div>
                    {{ form_end(commentForms[post.id]) }}
                {% endif %}

                <div class="mt-5">
                    <a href="{{ path('app_post_show', {id:post.id}) }}" class="mt-2 bg-gradient-to-r from-red-200 via-red-300 to-yellow-200 hover:bg-gradient-to-bl text-white px-4 py-2  rounded hover:bg-yellow-600">Read</a>
                </div>

            </div>

        {% endfor %}

    </div>
{% endblock %}
